# Copy to .env (or .env.local) and fill in.

# ───────────────────────── Email (Resend) ─────────────────────────
# Without these, the contact + newsletter forms run in safe "stub" mode.
RESEND_API_KEY=
EMAIL_FROM="Opus <onboarding@resend.dev>"
CONTACT_TO_EMAIL=you@yourdomain.com
RESEND_AUDIENCE_ID=

# ──────────────────────── TinaCMS (editing) ───────────────────────
# Local editing (`npm run dev` → /admin) needs NOTHING here — Tina runs
# in local mode. These are only for the DEPLOYED site's login + editing.
# Create a project at https://app.tina.io to get both values.
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
# Optional: branch Tina commits to (defaults to "main").
GITHUB_BRANCH=main
